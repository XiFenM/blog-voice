# LLM gateway used for translation, sentence enhancement, and audio QA.
# Get one at https://zenmux.ai — single key fronts OpenAI / Gemini / DeepSeek / etc.
ZENMUX_API_KEY=your_zenmux_api_key_here
# Optional fallback for `deepseek/*` models when ZenMux quota / network fails.
# Get one at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# Fish Audio TTS API. Get one at https://fish.audio/app/api-keys/
FISH_API_KEY=your_fish_audio_api_key_here
# Optional: HuggingFace mirror for chatterbox model download (first run)
# HF_ENDPOINT=https://hf-mirror.com
