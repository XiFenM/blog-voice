# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# playwright-cli local state + installed skills
.playwright/
.playwright-cli/
.claude/
.opencode/
opencode.json
.env

# Local model weights (downloaded on first run)
.model-cache/

# Copyrighted material — do not redistribute
/voices/
/voices_split/
/articles/*/source.txt
/articles/*/sentences.txt
/articles/*/sentences_normalized.txt
/articles/*/normalizations.json
/articles/*/sentences_enhanced.txt
/articles/*/enhancements.json
/articles/*/audio/
/articles/*/merged.wav
/articles/*/merged.m4a
/articles/*/subtitle.lrc
/articles/*/translations_zh.json
/articles/*/verify_report.json

# Generated logs / reports
tts_run.log
voice_mode_report.tsv

# Personal English-learning data: TEXT (weekly logs, feedback, Anki cards,
# progress notes) is now TRACKED so you can version your learning progress.
# Only AUDIO recordings stay out of git — they bloat history permanently and
# are personal voice data. (Keep the repo private if these logs are sensitive.)
/English-learn/**/*.m4a
/English-learn/**/*.wav
/English-learn/**/*.mp3
